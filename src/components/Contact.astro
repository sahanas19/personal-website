---
const links = [
  { label: "Email", href: "mailto:hi@sahana.cc" },
  { label: "GitHub", href: "https://github.com/sahanas19" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/sahana-subramanian-/" },
  { label: "X", href: "https://x.com/hauduluru" },
];
---

<section id="connect" class="border-t border-rule px-6 py-16">
  <div class="mx-auto max-w-2xl" data-reveal>
    <p class="font-display text-sm tracking-wide text-ink-soft">Connect</p>

    <p class="mt-8 max-w-md text-lg leading-relaxed text-ink">
      Say hello, or find me around the internet.
    </p>

    <ul class="mt-6 flex flex-wrap gap-x-8 gap-y-3 text-sm font-medium">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              target={link.href.startsWith("http") ? "_blank" : undefined}
              rel="noopener"
              class="group relative inline-flex items-center gap-1.5 text-ink transition hover:text-accent"
            >
              {link.label}
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
              <span
                aria-hidden="true"
                class="absolute -bottom-0.5 left-0 h-px w-full origin-left scale-x-0 bg-accent transition-transform duration-300 group-hover:scale-x-100"
              />
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
