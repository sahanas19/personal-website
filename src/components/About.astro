---
---

<section id="about" class="px-6 pb-16">
  <div class="mx-auto max-w-2xl" data-reveal>
    <p class="font-display text-sm tracking-wide text-ink-soft">About</p>

    <div class="mt-8 flex items-start gap-6">
      <img
        src="/photo.png"
        alt="Sahana Subramanian"
        class="h-36 w-36 shrink-0 rounded-full border border-rule object-cover sm:h-40 sm:w-40"
      />

      <div class="text-base leading-relaxed text-ink-soft">
        <p>
          I'm a Workday Consultant who helps organizations navigate the
          complexity of ERP transformation — turning messy processes into
          clean, working systems.
        </p>
        <p class="mt-3">
          Outside of work, I'm growing a small jungle of plants, plotting
          the next trip, chasing strength gains at the gym, and curating
          meal bowls that taste as good as they look.
        </p>

        <ul class="mt-5 flex flex-wrap gap-2">
          {
            ["Plants", "Travel", "Strength training", "Food"].map((tag) => (
              <li class="rounded-full border border-rule px-3 py-1 text-xs tracking-wide text-ink-soft">
                {tag}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
