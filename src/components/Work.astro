---
const projects = [
  {
    year: "2026",
    title: "Project One",
    description: "Short description of the project and what it does.",
    href: "#",
  },
  {
    year: "2025",
    title: "Project Two",
    description: "Short description of the project and what it does.",
    href: "#",
  },
  {
    year: "2024",
    title: "Project Three",
    description: "Short description of the project and what it does.",
    href: "#",
  },
];
---

<section id="work" class="border-t border-rule px-6 py-16">
  <div class="mx-auto max-w-2xl">
    <p class="font-display text-sm tracking-wide text-ink-soft" data-reveal>01 — Work</p>

    <ul class="mt-8 divide-y divide-rule">
      {
        projects.map((project, i) => (
          <li data-reveal style={`transition-delay: ${i * 80}ms`}>
            <a
              href={project.href}
              class="group relative flex items-start justify-between gap-6 py-6 pl-4 -ml-4 pr-2"
            >
              <span class="absolute left-0 top-1/2 h-0 w-px -translate-y-1/2 bg-accent transition-all duration-300 group-hover:h-[60%]" aria-hidden="true" />
              <div>
                <h3 class="font-display text-xl text-ink transition group-hover:text-accent">
                  {project.title}
                </h3>
                <p class="mt-1.5 max-w-md text-sm leading-relaxed text-ink-soft">
                  {project.description}
                </p>
              </div>
              <div class="flex shrink-0 items-center gap-3 pt-1 text-sm tabular-nums text-ink-soft">
                <span>{project.year}</span>
                <span class="transition group-hover:translate-x-0.5 group-hover:text-accent" aria-hidden="true">
                  &rarr;
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
