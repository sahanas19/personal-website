<section id="top" class="mx-auto max-w-2xl px-6 pb-16 pt-20 sm:pt-28">
  <h1 class="font-display text-4xl leading-tight text-ink sm:text-5xl">
    <span class="italic">Sahana Subramanian</span> — [your role or one-line
    positioning goes here].
  </h1>

  <p class="mt-6 max-w-lg text-lg leading-relaxed text-ink-soft">
    A couple of sentences introducing yourself — what you do, what you care
    about, and the kind of work you're drawn to. Write it like you'd say it
    out loud.
  </p>

  <div class="mt-8 flex items-center gap-2 text-sm text-ink-soft">
    <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
    Currently [doing X] in [your city]
  </div>

  <div class="mt-10 flex flex-wrap gap-x-8 gap-y-3 text-sm font-medium">
    <a href="#work" class="inline-flex items-center gap-1.5 text-ink transition hover:text-accent">
      See my work <span aria-hidden="true">&rarr;</span>
    </a>
    <a href="#connect" class="inline-flex items-center gap-1.5 text-ink transition hover:text-accent">
      Get in touch <span aria-hidden="true">&rarr;</span>
    </a>
  </div>
</section>
