      <a href="#connect" class="inline-flex items-center gap-1.5 text-ink transition hover:text-accent">
        Get in touch <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</section>

<style>
  .hero-in {
    animation: hero-in 0.7s ease both;
  }

  .hero-in-delay-1 {
    animation-delay: 0.1s;
  }

  @keyframes hero-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-in {
      animation: none;
    }
  }
</style>
