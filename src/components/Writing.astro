---
const posts = [
  {
    title: "AI transformations and WD!",
    status: "Coming soon",
  },
];
---

<section id="writing" class="border-t border-rule px-6 py-16">
  <div class="mx-auto max-w-2xl">
    <p class="font-display text-sm tracking-wide text-ink-soft" data-reveal>Writing</p>

    <p class="mt-8 max-w-md text-lg leading-relaxed text-ink" data-reveal>
      Notes on Workday, ERP, and the occasional detour.
    </p>

    <ul class="mt-6 space-y-3">
      {
        posts.map((post, i) => (
          <li
            data-reveal
            style={`transition-delay: ${(i + 1) * 80}ms`}
            class="flex flex-wrap items-center justify-between gap-x-6 gap-y-1.5 rounded-2xl border border-rule p-6"
          >
            <h3 class="font-display text-base text-ink">{post.title}</h3>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-accent/10 px-2.5 py-0.5 text-xs font-medium tracking-wide text-accent">
              <span class="relative flex h-1.5 w-1.5">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-75" />
                <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-accent" />
              </span>
              {post.status}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
