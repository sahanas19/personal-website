---
const links = [
  { href: "#about", label: "About" },
  { href: "#projects", label: "Projects" },
  { href: "#contact", label: "Contact" },
];
---

<header
  class="sticky top-0 z-50 border-b border-white/5 bg-slate-950/70 backdrop-blur-md"
>
  <div class="mx-auto flex max-w-4xl items-center justify-between px-6 py-4">
    <a
      href="#home"
      class="font-display text-sm font-semibold tracking-tight text-slate-100 hover:text-indigo-300"
    >
      Sahana Subramanian
    </a>

    <nav class="hidden gap-8 sm:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-sm text-slate-400 transition hover:text-slate-100"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <button
      id="nav-toggle"
      aria-label="Toggle menu"
      class="text-slate-200 sm:hidden"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
      </svg>
    </button>
  </div>

  <nav id="nav-menu" class="hidden flex-col gap-1 border-t border-white/5 px-6 py-3 sm:hidden">
    {
      links.map((link) => (
        <a
          href={link.href}
          class="rounded-md px-2 py-2 text-sm text-slate-300 hover:bg-white/5 hover:text-slate-100"
        >
          {link.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-menu");

  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    menu?.classList.toggle("flex");
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      menu.classList.remove("flex");
    });
  });
</script>
