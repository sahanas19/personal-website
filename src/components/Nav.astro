---
const links = [
  { href: "#work", label: "Work" },
  { href: "#connect", label: "Connect" },
];
---

<header
  class="sticky top-0 z-50 border-b border-rule/80 bg-paper/90 backdrop-blur-sm"
>
  <div class="mx-auto flex max-w-2xl items-center justify-between px-6 py-5">
    <a
      href="#top"
      class="font-display text-base font-medium tracking-tight text-ink"
    >
      Sahana Subramanian
    </a>

    <nav class="hidden gap-8 sm:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="group relative text-sm text-ink-soft transition hover:text-ink"
          >
            {link.label}
            <span class="absolute -bottom-1 left-0 h-px w-0 bg-accent transition-all group-hover:w-full" />
          </a>
        ))
      }
    </nav>

    <button
      id="nav-toggle"
      aria-label="Toggle menu"
      class="text-ink sm:hidden"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
      </svg>
    </button>
  </div>

  <nav id="nav-menu" class="hidden flex-col gap-1 border-t border-rule px-6 py-3 sm:hidden">
    {
      links.map((link) => (
        <a
          href={link.href}
          class="rounded-md px-2 py-2 text-sm text-ink-soft hover:bg-ink/5 hover:text-ink"
        >
          {link.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-menu");

  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    menu?.classList.toggle("flex");
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      menu.classList.remove("flex");
    });
  });
</script>
