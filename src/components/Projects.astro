---
const projects = [
  {
    title: "Project One",
    description: "Short description of the project and what it does.",
    href: "#",
  },
  {
    title: "Project Two",
    description: "Short description of the project and what it does.",
    href: "#",
  },
  {
    title: "Project Three",
    description: "Short description of the project and what it does.",
    href: "#",
  },
];
---

<section id="projects" class="border-y border-white/5 bg-white/[0.02] px-6 py-20">
  <div class="mx-auto max-w-4xl">
    <h2 class="font-display text-2xl font-semibold text-slate-50">Projects</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        projects.map((project) => (
          <a
            href={project.href}
            class="group rounded-2xl border border-white/10 bg-slate-950/60 p-6 transition hover:-translate-y-0.5 hover:border-indigo-300/30 hover:bg-slate-900/80"
          >
            <h3 class="font-display text-lg font-medium text-slate-100">
              {project.title}
            </h3>
            <p class="mt-2 text-sm text-slate-400">{project.description}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-indigo-300">
              View project
              <span class="transition group-hover:translate-x-0.5">&rarr;</span>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
