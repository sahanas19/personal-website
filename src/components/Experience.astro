---
const role = {
  period: "Present",
  title: "Manager, Workday Consulting",
  company: "PwC",
  description:
    "Helping organizations navigate the complexity of ERP transformation — turning messy processes into clean, working systems.",
};

const previousRoles = [
  {
    title: "Consultant",
    company: "Deloitte",
    period: "2019 - 2022",
    description:
      "Progressed from Associate Consultant to Consultant delivering Workday Financials implementations.",
  },
  {
    title: "Workday Financials Functional Consultant",
    company: "KPMG Global Services",
    period: "2018 - 2019",
    description:
      "Configured and supported Workday Financials modules for global clients.",
  },
];
---

<section id="experience" class="border-t border-rule px-6 py-16">
  <div class="mx-auto max-w-2xl">
    <p class="font-display text-sm tracking-wide text-ink-soft" data-reveal>Experience</p>

    <div
      class="mt-8 rounded-2xl border border-rule bg-ink/[0.02] p-6 sm:p-8"
      data-reveal
    >
      <div class="flex flex-wrap items-start justify-between gap-x-6 gap-y-2">
        <div>
          <div class="flex flex-wrap items-center gap-2.5">
            <h3 class="font-display text-xl text-ink sm:text-2xl">{role.title}</h3>
            <span class="rounded-full bg-accent/10 px-2.5 py-0.5 text-xs font-medium tracking-wide text-accent">
              {role.period}
            </span>
          </div>
          <p class="mt-1 text-sm text-ink-soft">{role.company}</p>
        </div>
      </div>
      <p class="mt-4 max-w-lg text-sm leading-relaxed text-ink-soft">
        {role.description}
      </p>
    </div>

    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      {
        previousRoles.map((prev, i) => (
          <div
            data-reveal
            style={`transition-delay: ${(i + 1) * 80}ms`}
            class="rounded-2xl border border-rule p-6"
          >
            <div class="flex flex-wrap items-center gap-2">
              <h4 class="font-display text-base text-ink">{prev.title}</h4>
              <span class="text-xs font-medium tracking-wide text-ink-soft/70">
                {prev.period}
              </span>
            </div>
            <p class="mt-1 text-sm text-ink-soft">{prev.company}</p>
            <p class="mt-1.5 text-sm leading-relaxed text-ink-soft/80">
              {prev.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
