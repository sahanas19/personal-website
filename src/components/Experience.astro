---
const companies = [
  {
    name: "PwC Acceleration Centers",
    duration: "3 years 11 months",
    roles: [
      {
        title: "Manager",
        period: "June 2024 - Present (2 years 2 months)",
        location: "Bengaluru, Karnataka, India",
      },
      {
        title: "Senior Associate 2",
        period: "July 2023 - June 2024 (1 year)",
        location: "Bengaluru, Karnataka, India",
      },
      {
        title: "Senior Associate",
        period: "September 2022 - July 2023 (11 months)",
        location: "Bengaluru, Karnataka, India",
      },
    ],
  },
  {
    name: "Deloitte",
    duration: "3 years 2 months",
    roles: [
      {
        title: "Consultant",
        period: "November 2021 - August 2022 (10 months)",
        location: "Bengaluru, Karnataka, India",
      },
      {
        title: "Associate Consultant",
        period: "July 2019 - November 2021 (2 years 5 months)",
        location: "Bengaluru, Karnataka",
      },
    ],
  },
  {
    name: "KPMG Global Services (KGS)",
    duration: null,
    roles: [
      {
        title: "Workday Financials Functional Consultant",
        period: "June 2018 - July 2019 (1 year 2 months)",
        location: "Bengaluru Area, India",
      },
    ],
  },
];
---

<section id="experience" class="border-t border-rule px-6 py-16">
  <div class="mx-auto max-w-2xl">
    <p class="font-display text-sm tracking-wide text-ink-soft" data-reveal>Experience</p>

    <ol class="mt-8 border-l border-rule">
      {
        companies.map((company, i) => (
          <li
            data-reveal
            style={`transition-delay: ${(i + 1) * 80}ms`}
            class="relative pb-10 pl-8 last:pb-0"
          >
            <span class="absolute -left-[5px] top-1.5 h-2.5 w-2.5 rounded-full bg-accent" />

            <h3 class="font-display text-lg text-ink sm:text-xl">{company.name}</h3>
            {company.duration && (
              <p class="mt-0.5 text-xs tracking-wide text-ink-soft/70">{company.duration}</p>
            )}

            <div class="mt-4 space-y-4">
              {company.roles.map((role) => (
                <div>
                  <h4 class="text-sm font-medium text-ink">{role.title}</h4>
                  <p class="mt-0.5 text-sm text-ink-soft">{role.period}</p>
                  <p class="mt-0.5 text-xs text-ink-soft/60">{role.location}</p>
                </div>
              ))}
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
